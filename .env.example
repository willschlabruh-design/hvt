# HVTDEVIL — Contact form environment variables
# Copy to .env for local `npm start`, or set in Cloudflare Pages → Settings → Environment variables.

# ── Required (all deployments) ─────────────────────────────────────
# Inbox that receives support form submissions
SUPPORT_EMAIL=william.schlanbusch@gmail.com

# ── Cloudflare Pages (recommended): Resend HTTP API ────────────────
# Nodemailer/SMTP does NOT run on Cloudflare Workers — use Resend there.
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_your_api_key_from_resend_dashboard
# Sender address (see Resend notes below)
FROM_EMAIL=onboarding@resend.dev

# ── Local Node server (npm start): Gmail / SMTP via nodemailer ─────
# EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=william.schlanbusch@gmail.com
# SMTP_PASS=your_gmail_app_password
# SMTP_FROM="HVTDEVIL Support <william.schlanbusch@gmail.com>"

# ── Optional ───────────────────────────────────────────────────────
# Include provider debug details in API JSON errors (staging only)
# CONTACT_DEBUG=true

# Server port for npm start (default 3000)
# PORT=3000
