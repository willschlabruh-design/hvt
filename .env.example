# HVTDEVIL — Environment configuration
# Copy this file to .env and fill in your values.

# Email address that receives support form submissions
SUPPORT_EMAIL=william.schlanbusch@gmail.com

# SMTP settings (Gmail, SendGrid, Mailgun, etc.)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password

# Optional: custom From header (defaults to SMTP_USER)
# SMTP_FROM="HVTDEVIL Support <noreply@hvtddevil.com>"

# Server port when running npm run start (default 3000)
# PORT=3000
